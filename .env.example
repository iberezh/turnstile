# --- API ---
DATABASE_URL=postgresql://turnstile:turnstile@localhost:5436/turnstile
# Signs the auth cookie. Change for anything beyond local.
JWT_SECRET=dev-only-insecure-change-me
PORT=4002
# Browser origin allowed to send the auth cookie (the Nuxt app).
WEB_ORIGIN=http://localhost:3003

# --- Stripe (Connect) --- leave blank to run with the mock payments adapter
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_CONNECT_CLIENT_ID=

# --- Postgres (docker) --- dedicated host port to avoid other local Postgres instances
POSTGRES_PORT=5436

# --- Admin control plane (apps/admin-api) --- runs as a SEPARATE service on its OWN database,
# so a breach of the app DB/credentials above can't reach admin identities or the platform audit.
ADMIN_DATABASE_URL=postgresql://turnstile_admin:turnstile_admin@localhost:5437/turnstile_admin
# The main app DB the control plane acts on (suspend org / moderate event).
APP_DATABASE_URL=postgresql://turnstile:turnstile@localhost:5436/turnstile
# Distinct from JWT_SECRET — a stolen tenant session must not authenticate against the admin API.
ADMIN_JWT_SECRET=admin-dev-only-insecure-change-me
ADMIN_PORT=4003
ADMIN_WEB_ORIGIN=http://localhost:3004
ADMIN_POSTGRES_PORT=5437
# Bootstrap superadmin (seeded once when admin_users is empty). TOTP secret auto-generated if blank.
BOOTSTRAP_ADMIN_EMAIL=root@turnstile.local
BOOTSTRAP_ADMIN_PASSWORD=change-me-now-please
BOOTSTRAP_ADMIN_TOTP_SECRET=

# --- Admin console (apps/admin-web, port 3004) --- the operator UI over the admin-api.
NUXT_PUBLIC_ADMIN_API_BASE=http://localhost:4003/admin/v1
