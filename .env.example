# --- API ---
DATABASE_URL=postgresql://turnstile:turnstile@localhost:5432/turnstile
# Signs the auth cookie. Change for anything beyond local.
JWT_SECRET=dev-only-insecure-change-me
PORT=4000
# Browser origin allowed to send the auth cookie (the Nuxt app).
WEB_ORIGIN=http://localhost:3000

# --- Stripe (Connect) --- leave blank to run with the mock payments adapter
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_CONNECT_CLIENT_ID=

# --- Postgres (docker) --- override if 5432 is taken locally
POSTGRES_PORT=5432
